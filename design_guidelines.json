{
  "theme": "dark",
  "archetype": "Archetype 5 (Luxury) + Archetype 4 (Swiss & High-Contrast)",
  "design_philosophy": "Cinematic, Futuristic, Premium, Intelligent, Sophisticated, Highly interactive, Expensive. Dark luxury tech aesthetic.",
  "colors": {
    "primary_bg": "#050505",
    "secondary_bg": "#0A0A0A",
    "carbon_graphite": "#121212",
    "primary_accent": "#007AFF", 
    "royal_purple": "#5E5CE6",
    "platinum_silver": "#EBEBF5",
    "deep_cyan": "#32ADE6",
    "soft_violet": "#AF52DE",
    "emerald": "#34C759",
    "warm_white": "#F2F2F7",
    "text_primary": "#FFFFFF",
    "text_secondary": "rgba(255, 255, 255, 0.7)",
    "text_tertiary": "rgba(255, 255, 255, 0.4)",
    "border_subtle": "rgba(255, 255, 255, 0.08)"
  },
  "typography": {
    "heading_font": "Cabinet Grotesk",
    "body_font": "Satoshi",
    "mono_font": "JetBrains Mono",
    "hierarchy": {
      "h1": "text-5xl sm:text-6xl tracking-tighter font-medium",
      "h2": "text-3xl sm:text-4xl tracking-tight font-medium",
      "h3": "text-xl sm:text-2xl font-medium",
      "body": "text-base leading-relaxed text-white/70",
      "mono_label": "text-xs tracking-[0.2em] uppercase font-mono text-white/50"
    }
  },
  "glassmorphism_tokens": {
    "surface": "bg-white/[0.02]",
    "surface_hover": "hover:bg-white/[0.04]",
    "blur": "backdrop-blur-2xl",
    "border": "border border-white/[0.08]",
    "border_hover": "hover:border-white/[0.15]",
    "shadow": "shadow-[0_8px_32px_rgba(0,0,0,0.5)]",
    "inner_glow": "box-shadow: inset 0 1px 0 0 rgba(255,255,255,0.1)"
  },
  "lighting_recipes": {
    "aurora_orb": "absolute rounded-full blur-[100px] opacity-30 mix-blend-screen",
    "mouse_glow": "radial-gradient(600px circle at var(--mouse-x) var(--mouse-y), rgba(255,255,255,0.06), transparent 40%)",
    "card_spotlight": "radial-gradient(800px circle at var(--mouse-x) var(--mouse-y), rgba(255,255,255,0.04), transparent 40%)"
  },
  "animations": {
    "easing": "cubic-bezier(0.16, 1, 0.3, 1)",
    "duration_fast": "200ms",
    "duration_normal": "400ms",
    "duration_slow": "800ms",
    "hover_transform": "-translate-y-1 scale-[1.02]",
    "parallax_speed": "0.1 to 0.3",
    "reveal_on_scroll": "opacity-0 translate-y-8 -> opacity-100 translate-y-0"
  },
  "component_specs": {
    "hero": {
      "layout": "min-h-screen flex flex-col justify-center items-center relative overflow-hidden",
      "background": "Cinematic video + TSParticles canvas overlay + bg-black/60 overlay",
      "content_alignment": "center",
      "text_style": "Cabinet Grotesk, massive text with gradient text fill (silver to white)",
      "cta_button": "Glassmorphic button with inner glow, backdrop-blur, and tracking beam border effect"
    },
    "service_cards": {
      "layout": "Bento grid or 3-column grid",
      "style": "Frosted glass card, 1px subtle border, soft inner glow",
      "interaction": "Tilt-on-hover (framer-motion or vanilla-tilt), mouse-reactive spotlight background",
      "iconography": "Phosphor icons (Duotone) in primary accent color"
    },
    "project_showcase": {
      "layout": "Overlapping or wide bento-style cards",
      "style": "Dark gradient backgrounds, high-res dashboard mockups",
      "interaction": "3D perspective shift on hover, expand details"
    },
    "timeline": {
      "layout": "Vertical line with glowing nodes, or horizontal scroller",
      "style": "Neon blue/purple glowing line on active state",
      "interaction": "Nodes light up as scrolled into view"
    },
    "testimonials": {
      "layout": "Auto-sliding infinite marquee or carousel",
      "style": "Glass cards, soft particle effects in background",
      "avatar": "grayscale image with color reveal on hover"
    },
    "cta_section": {
      "layout": "Massive padding (py-32), central alignment",
      "style": "Animated aurora lights (CSS gradients blur-[120px]) behind the text",
      "button": "Magnetic hover effect"
    }
  },
