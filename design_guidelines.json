  "libraries": {
    "icons": "@phosphor-icons/react",
    "animations": "framer-motion",
    "particles": "tsparticles",
    "scrolling": "lenis"
  },
  "testing": {
    "attributes": "data-testid",
    "convention": "kebab-case, role-based"
  },
  "instructions_to_main_agent": [
    "Ensure global background is set to the dark gradient or #050505.",
    "Implement mouse-reactive spotlight effect using CSS vars tracked via React state/ref on cards.",
    "Use Cabinet Grotesk for Headings and Satoshi for body. Use JetBrains Mono for overlines and stats.",
    "Use TSParticles layered on top of the hero background video for the 'particles overlay' effect.",
    "Project cards should have tilt effect (e.g., using framer-motion useMotionValue).",
    "Install and use Lenis for smooth scrolling.",
    "Ensure all interactive elements have data-testid attributes."
  ]
}